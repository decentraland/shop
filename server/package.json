{
  "name": "shop-server",
  "version": "0.1.0",
  "description": "Treasury/settlement backend for the Decentraland Shop. Keeps the CreditsManager funded with MANA by converting USDC backing, and reconciles the books.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --trace-warnings --abort-on-uncaught-exception --unhandled-rejections=strict dist/index.js",
    "start:dev": "nodemon --exec ts-node src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p test/tsconfig.json",
    "test": "jest --forceExit --detectOpenHandles --coverage --verbose",
    "lint:check": "eslint '**/*.{js,ts}'",
    "lint:fix": "eslint '**/*.{js,ts}' --fix",
    "db:migrate": "node-pg-migrate --tsconfig ./tsconfig.json --migrations-dir ./src/migrations"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none",
    "tabWidth": 2
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.10",
    "@well-known-components/test-helpers": "^1.5.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@dcl/schema-validator-component": "^0.2.0",
    "@dcl/schemas": "^19.4.0",
    "@well-known-components/env-config-provider": "^1.2.0",
    "@well-known-components/fetch-component": "^3.0.0",
    "@well-known-components/http-server": "^2.1.0",
    "@well-known-components/interfaces": "^1.5.1",
    "@well-known-components/logger": "^3.1.3",
    "@well-known-components/metrics": "^2.1.0",
    "@well-known-components/pg-component": "^1.1.0",
    "ethers": "^5.8.0",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "sql-template-strings": "^2.2.2"
  }
}
