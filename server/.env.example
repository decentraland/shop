# shop-server treasury — example PRODUCTION configuration.
# Copy to .env and fill with real values. ALL VALUES BELOW ARE FAKE PLACEHOLDERS.
# Never commit real secrets. Production custody is KMS only — no raw private key anywhere.

ENV=prd
NODE_ENV=production
HTTP_SERVER_PORT=3000
HTTP_SERVER_HOST=0.0.0.0

# --- Chain (Polygon mainnet) ---
CHAIN_ID=137
RPC_ENDPOINT_POLYGON=https://polygon-rpc.example.com/YOUR_KEY

# On mainnet every address must be provided (no baked-in defaults for chain 137).
MANA_ADDRESS=0xEXAMPLE0000000000000000000000000000mana
USDC_ADDRESS=0xEXAMPLE0000000000000000000000000000usdc
MANA_USD_ORACLE_ADDRESS=0xEXAMPLE00000000000000000000000000oracle
CREDITS_MANAGER_ADDRESS=0xEXAMPLE0000000000000000000000000creditsm
MARKETPLACE_ADDRESS=0xEXAMPLE000000000000000000000000000market

# --- Custody signer: KMS (production) ---
SIGNER_MODE=kms
# AWS KMS asymmetric key (ECC_SECG_P256K1, SIGN_VERIFY). Key material never leaves KMS.
KMS_KEY_ID=arn:aws:kms:us-east-1:000000000000:key/EXAMPLE-key-id
AWS_REGION=us-east-1
# ALLOW_DEV_SIGNER must NOT be set in production; the dev signer is refused when NODE_ENV=production.

# --- Swap backend: DEX aggregator (production) ---
SWAP_MODE=dex
DEX_AGGREGATOR_URL=https://polygon.api.0x.example.com
SWAP_SLIPPAGE_BPS=100
SWAP_ORACLE_SPREAD_BUFFER_BPS=50

# --- Refill strategy + thresholds (MANA in human/ether units) ---
REFILL_STRATEGY=working-balance
REFILL_TARGET_MANA=5000
REFILL_THRESHOLD_MANA=1000
REFILL_MIN_MANA=50
REFILL_INTERVAL_MS=30000

# --- Postgres ---
PG_COMPONENT_PSQL_CONNECTION_STRING=postgres://user:pass@db.example.com:5432/shop_treasury

# --- Internal admin token guarding /treasury/* endpoints ---
API_ADMIN_TOKEN=sk-example123-rotate-me
