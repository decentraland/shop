# Where the signed USD-pegged trade is POSTed — your LOCAL marketplace-server running the
# feat/support-usd-pegged-trades branch.
VITE_MARKETPLACE_SERVER_URL=http://localhost:5003

# Where owned NFTs / catalog are READ from. Defaults to the local server (dev DB: Amoy + Sepolia).
# Override to read from .zone instead:
# VITE_NFT_API_URL=https://marketplace-api.decentraland.zone
VITE_NFT_API_URL=http://localhost:5003

# Target chain for testing (Amoy = 80002).
VITE_CHAIN_ID=80002

# Credits service for buy-with-credits (default local port 3000). Run credits-server with
# ALLOW_DEV_MINT=true to mint test credits via POST /dev/mint-credit.
VITE_CREDITS_SERVER_URL=http://localhost:3000

# Catalyst peer for profile avatars in the navbar (.zone for testnet, .org for prod).
VITE_PEER_URL=https://peer.decentraland.zone

# --- Get credits (buy a credit pack with a card) ---------------------------------
# shop-server base URL (Stripe checkout + webhook + credit grant). Leave EMPTY to run
# the get-credits flow fully MOCKED (no backend needed — great for local UI work/demo).
# VITE_SHOP_SERVER_URL=http://localhost:5100
VITE_SHOP_SERVER_URL=

# Stripe TEST-mode publishable key (pk_test_…). Leave EMPTY to use the built-in mock.
# NEVER put a Stripe secret key (sk_…) in the frontend — that lives only on shop-server.
# VITE_STRIPE_PK=pk_test_example123
VITE_STRIPE_PK=
