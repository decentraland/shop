# Shop configuration lives in src/config/env/{dev,stg,prod}.json and is chosen at RUNTIME by hostname
# (decentraland.org → prod, *.decentraland.zone → dev/stg), with a `?env=` query override. One build
# serves every environment — see src/config/index.ts.
#
# You normally do NOT need any .env file: `npm run dev` uses the DEVELOPMENT config (.zone testnet).
# Copy this to `.env.local` ONLY to override hosts for local development against a LOCAL backend stack.
# Any VITE_* set here wins over the per-env JSON. All VITE_* are baked into the client bundle — never a secret.

# Point catalog reads/writes at a local marketplace-server instead of .zone:
# VITE_MARKETPLACE_SERVER_URL=http://localhost:5003
# VITE_NFT_API_URL=http://localhost:5003

# Point buy-with-credits at a local credits-server (run it with ALLOW_DEV_MINT=true for test credits):
# VITE_CREDITS_SERVER_URL=http://localhost:3000

# Force a specific environment locally (default: dev) — or just use ?env=prod in the browser:
# VITE_DCL_DEFAULT_ENV=dev

# Get-credits / Stripe: empty JSON values keep the flow MOCKED. Override to test a real widget locally:
# VITE_SHOP_SERVER_URL=http://localhost:5100
# VITE_STRIPE_PK=pk_test_example123

# Analytics: set the real Segment write key per-env in the JSONs; override here only for a local smoke test.
# VITE_SEGMENT_WRITE_KEY=

# Error monitoring (Sentry): the DSN lives in the per-env JSONs (public ingest key, never a secret).
# Empty → monitoring no-ops. Override here only for a local smoke test; NEVER put a Sentry AUTH token here.
# VITE_SENTRY_DSN=https://example@o0.ingest.sentry.io/0
# VITE_SENTRY_ENVIRONMENT=dev
# VITE_SENTRY_RELEASE=shop@0.0.0-dev
